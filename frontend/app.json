{
  "expo": {
    "name": "frontend",
    "slug": "frontend",
    "scheme": "nestham",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/SelectoLogo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/SelectoLogo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "This app needs access to your photos to upload a profile picture and documents.",
        "NSCameraUsageDescription": "This app may use the camera for profile or document photos.",
        "NSMicrophoneUsageDescription": "This app needs the microphone to record your voice verification."
      }
    },
    "android": {
      "package": "com.kaushikvishwas.frontend",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.USE_FULL_SCREEN_INTENT"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": false,
          "data": [{ "scheme": "nestham" }],
          "category": ["BROWSABLE", "DEFAULT"]
        },
        {
          "action": "VIEW",
          "autoVerify": false,
          "data": [
            {
              "scheme": "nestham",
              "host": "incoming-call"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/SelectoLogo.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "androidStatusBar": {
      "backgroundColor": "#ffffff",
      "barStyle": "dark-content",
      "translucent": false
    },
    "androidNavigationBar": {
      "backgroundColor": "#ffffff",
      "barStyle": "dark-content"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "defaultChannel": "incoming_calls"
        }
      ],
      "./plugins/withIncomingCallFcm.js"
    ],
    "web": {
      "favicon": "./assets/SelectoLogo.png"
    },
    "extra": {
      "apiBaseUrl": "https://backend.nesthamapp.com",
      "cloudinaryCloudName": "dfeeqvx3v",
      "cloudinaryUploadPreset": "dating_app_upload"
    }
  }
}
