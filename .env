# =============================================================================
# Single environment file for this repo (project root).
# Backend loads this automatically. Admin panel (Vite) reads VITE_* from here.
# If you still use backend/.env, copy values into this file — root .env wins when both exist.
# =============================================================================

# --- Database ---
MONGODB_URI=mongodb+srv://kaushik_vishwas:aV84mhxg4SPM1WZQ@cluster0.aswdhov.mongodb.net/?appName=Cluster0

# --- Server ---
PORT=5000

# --- App user JWT ---
JWT_SECRET=your_secret_key

# --- Gmail SMTP (OTP / password reset). App password, 2FA on Google account. ---
EMAIL_USER=kaushikbiawas@gmail.com
EMAIL_PASS=uycajrmvxwqktwoy

# --- Dev only: skip real OTP verification (never true in production) ---
OTP_BYPASS=false

# --- Admin API JWT (separate from app users) ---
ADMIN_JWT_SECRET=admin_panel_jwt_signing_key_dev_only_replace_in_prod

# --- Super admin (single account; backend syncs on startup, removes other admins) ---
ADMIN_EMAIL=kaushikvishwascse@gmail.com
ADMIN_NAME=Super Admin

# Optional: npm run seed:admin in /backend sets this password (min 8 chars)
ADMIN_PASSWORD=Admin@123

# --- Admin panel (Vite): API base URL, no trailing slash ---
VITE_API_URL=http://localhost:5000

# --- Mobile app (Expo): copy these into frontend/.env if you use the app ---
# EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=
