{
  "name": "dating-app-auth-backend",
  "version": "1.0.0",
  "description": "Express + MongoDB JWT auth with email OTP for dating app",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only server.ts",
    "build": "tsc -p tsconfig.json && node scripts/copyReferralLandingConfig.js",
    "prestart": "npm run build",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "seed:admin": "tsx scripts/seedAdmin.ts",
    "migrate:split-users": "tsx scripts/migrateSplitUsersReceivers.ts",
    "migrate:caller-suspended": "tsx scripts/migrateCallerAccessSuspendedOnly.ts",
    "migrate:drop-email-indexes": "tsx scripts/migrateDropEmailIndexes.ts",
    "test:voice-gender-api": "tsx scripts/testVoiceGenderApi.ts",
    "test:local-voice-gender": "tsx scripts/testLocalVoiceGender.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@huggingface/inference": "^4.13.18",
    "@huggingface/transformers": "^4.2.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.8.0",
    "nodemailer": "^6.9.16",
    "razorpay": "^2.9.6",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/nodemailer": "^7.0.11",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.5.4"
  }
}
